ELASTIC_VERSION=9.4.0
LOGSTASH_SYSLOG_TIMEZONE=Africa/Casablanca

# Kibana needs stable encryption keys for dashboards, actions, alerting,
# sessions, and reporting. Replace these values for a real deployment.
KIBANA_ENCRYPTEDSAVEDOBJECTS_KEY=ssh-web-firewall-demo-encrypted-saved-objects-key-32
KIBANA_SECURITY_KEY=ssh-web-firewall-demo-security-key-32-characters
KIBANA_REPORTING_KEY=ssh-web-firewall-demo-reporting-key-32-characters
